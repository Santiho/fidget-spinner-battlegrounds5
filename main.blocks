Q</field><value name="A"><shadow type="math_number" id="%[~8U51W@gtR?:`5y5[`"><field name="NUM">0</field></shadow><block type="variables_get" id="djcJUm{BzXHskg0%+Rt?"><field name="VAR" id="@3!J=.Vpw5jj0ICQ[[TJ">tutorial</field></block></value><value name="B"><shadow type="math_number" id="?yVDtj21g(PIPjEFG$x#"><field name="NUM">0</field></shadow></value></block></value><statement name="DO0"><block type="variables_set" id="{b?s^AXotKV#Wly!80%*"><field name="VAR" id="@3!J=.Vpw5jj0ICQ[[TJ">tutorial</field><value name="VALUE"><shadow type="math_number" id="9y-|5idj`L/F.e}3ufE_"><field name="NUM">1</field></shadow></value><next><block type="story_sprite_say_text" id="x;@3SehmGf!ajr]?^us@"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="sprite"><block type="variables_get" id="17Fh@SeIC}ZF8WF=[D5n"><field name="VAR" id="N1Zje4P8ychU/tCeZdaw">mySprite4</field></block></value><value name="text"><shadow type="text" id="f]J@Fm2C~k47E,HX*Ezj"><field name="TEXT">Hello do you want a tutorial?</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="K+7zcU-j?/-De#s!lDbF"><field name="index">15</field></shadow></value><value name="background"><shadow type="colorindexpicker" id="z8VT{wCV{FuiX*Z/F/(_"><field name="index">1</field></shadow></value><next><block type="arcade_story_show_player_choices" id="mQow=p*dr8~2qf]=`!~c"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="-c]fHfJ3/`?8]FudcfkB"><field name="TEXT">Sure!</field></shadow></value><value name="choice2"><shadow type="text" id="O_pU::]NAu?}8CaTh%g{"><field name="TEXT">Nah I'm good.</field></shadow></value><value name="choice3"><shadow type="text" id="|xK9quQ.{N1Z^HqsfltN"><field name="TEXT"></field></shadow></value><value name="choice4"><shadow type="text" id="/;o7+bH7bJz}bgE9XIT,"><field name="TEXT"></field></shadow></value><value name="choice5"><shadow type="text" id="aD9Zhrx^OMJyXalKh_DT"><field name="TEXT"></field></shadow></value><next><block type="controls_if" id="*Ei@?aujvO846B]k@PtR"><value name="IF0"><shadow type="logic_boolean" id="D4IgAHP{[{ThGE=.[A/R"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="+|-JG;[5D(P)uP4[2a5s"><value name="choice"><shadow type="text" id="PoeCNs1KAIqR`VFXIZ/G"><field name="TEXT">Sure!</field></shadow></value></block></value><statement name="DO0"><block type="story_sprite_say_text" id="hwQPW9D+rVCL.5H#dshr"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="sprite"><block type="variables_get" id="@IfGz,*Dj+9/DIx6zy?Q"><field name="VAR" id="N1Zje4P8ychU/tCeZdaw">mySprite4</field></block></value><value name="text"><shadow type="text" id="kosI.#%z6V5X|6$R[@Rh"><field name="TEXT">Things around here are simple!</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="6D.m~qJ7q:{XyI{q_Yj3"><field name="index">15</field></shadow></value><value name="background"><shadow type="colorindexpicker" id="E!+illT5Y~Rwuld!;g|r"><field name="index">1</field></shadow></value><next><block type="story_sprite_say_text" id="8WBRo:GdKxS8E6EQ];ro"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="sprite"><block type="variables_get" id="A~lykP]#Ha4nxV]e*`b="><field name="VAR" id="N1Zje4P8ychU/tCeZdaw">mySprite4</field></block></value><value name="text"><shadow type="text" id="*1S|npZ92ZA.TGuNBG0-"><field name="TEXT">On your top right there should be a number. That is the amount of credits you have.</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="/^UQC.c81q{3]MWc}.4]"><field name="index">15</field></shadow></value><value name="background"><shadow typ